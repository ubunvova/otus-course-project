<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping">
    <entity name="App\Domain\User\User" table="users">
        <id name="id" type="uuid" column="id">
            <generator strategy="NONE" />
        </id>

        <field name="name" type="string" length="255" nullable="false"/>
        <field name="apiKey" type="string" length="64" nullable="false" unique="true"/>

        <field name="createdAt" type="datetimetz_immutable"/>
    </entity>
</doctrine-mapping>
